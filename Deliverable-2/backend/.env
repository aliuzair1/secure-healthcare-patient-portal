# ---- Flask ----
FLASK_ENV=development
FLASK_SECRET_KEY=change-this-to-a-long-random-secret

# ---- Supabase ----
# Found in Supabase dashboard → Settings → API
SUPABASE_URL= https://yyynpckjfvrhfggjjkcc.supabase.co
SUPABASE_SERVICE_ROLE_KEY= sb_publishable_t7LnWkjhMBDZiV-4Vd2xtA_CHrWndlx
SUPABASE_JWT_SECRET=your-jwt-secret-here
# The JWT secret is under Settings → API → JWT Settings

# ---- CORS ----
# Comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:5173,https://secure-healthcare-patient-portal.vercel.app

# ---- Rate limiting ----
# Use Redis in production: redis://localhost:6379
RATELIMIT_STORAGE_URI=memory://

# ---- App URL (used in password reset emails) ----
APP_URL=http://localhost:5173

# ---- Signature WAF ----
# WAF_ADMIN_KEY: secret for all /waf/admin/* endpoints.
# MUST be changed to a strong random value in production.
WAF_ADMIN_KEY=change-this-to-a-strong-random-key
# WAF_ENV controls HSTS header injection (set to "production" in prod).
WAF_ENV=development
# WAF_FAIL_OPEN=true allows requests through when the WAF hits an internal
# error. Keep false (fail-closed) for healthcare data.
WAF_FAIL_OPEN=false
# WAF_DEBUG=true enables verbose WAF console logging. Keep false in prod.
WAF_DEBUG=false
